{
    "name": "__MSG_ext_name__",
    "description": "__MSG_manifest_description__",
    "version": "1.0.0.2",
    "version_name": "1.0.0.2",
    "default_locale": "en",
    "manifest_version": 3,
    "icons": {
        "48": "/assets/icon48.png",
        "32": "/assets/icon32.png",
        "16": "/assets/icon16.png"
    },
    "action": {
        "default_icon": {
            "48": "/assets/icon48.png",
            "32": "/assets/icon32.png",
            "16": "/assets/icon16.png"
        },
        "default_title": "__MSG_ext_name__"
    },
    "permissions": [
        "activeTab",
        "debugger",
        "downloads",
        "tabs",
        "webNavigation"
    ],
    "host_permissions": [
        "*://rezka.ag/*",
        "*://hdrezka.cm/*",
        "*://hdrezka.me/*",
        "*://hdrezka.ag/*",
        "*://hdrezka.co/*",
        "*://rezka-ua.in/*",
        "*://rezka-ua.co/*",
        "*://rezka-ag.net/*",
        "*://rezka-tv.to/*"
    ],
    "background": {
        "service_worker": "service_worker.js"
    },    
    "content_scripts": [
        {
            "matches": [
                "*://rezka.ag/*",
                "*://hdrezka.cm/*",
                "*://hdrezka.me/*",
                "*://hdrezka.ag/*",
                "*://hdrezka.co/*",
                "*://rezka-ua.in/*",
                "*://rezka-ua.co/*",
                "*://rezka-ag.net/*",
                "*://rezka-tv.to/*"
            ],
            "js": ["isolated.js"]
        },
        {
            "matches": [
                "*://rezka.ag/*",
                "*://hdrezka.cm/*",
                "*://hdrezka.me/*",
                "*://hdrezka.ag/*",
                "*://hdrezka.co/*",
                "*://rezka-ua.in/*",
                "*://rezka-ua.co/*",
                "*://rezka-ag.net/*",
                "*://rezka-tv.to/*"
            ],
            "js": ["main.js"],
            "world": "MAIN"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "/assets/*"
            ],
            "matches": [ 
                "*://rezka.ag/*",
                "*://hdrezka.cm/*",
                "*://hdrezka.me/*",
                "*://hdrezka.ag/*",
                "*://hdrezka.co/*",
                "*://rezka-ua.in/*",
                "*://rezka-ua.co/*",
                "*://rezka-ag.net/*",
                "*://rezka-tv.to/*"
            ],
            "use_dynamic_url": true
        }
    ],
    "author": "Dmytro Kazankov", 
    "homepage_url": "https://github.com/dkazankov/yard"
}