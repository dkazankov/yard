{
    "name": "__MSG_ext_name__",
    "description": "__MSG_manifest_description__",
    "version": "1.1",
    "version_name": "1.1",
    "default_locale": "en",
    "manifest_version": 3,
    "icons": {
        "48": "/assets/icon48.png",
        "32": "/assets/icon32.png",
        "16": "/assets/icon16.png"
    },
    "action": {
        "default_icon": {
            "48": "/assets/icon48.png",
            "32": "/assets/icon32.png",
            "16": "/assets/icon16.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "https://rezka.ag/*",
                "https://hdrezka.cm/*",
                "https://hdrezka.me/*",
                "https://hdrezka.ag/*",
                "https://hdrezka.co/*",
                "https://rezka-ua.in/*",
                "https://rezka-ua.co/*"
            ],
            "js": ["content_script.js"]
        }
    ],
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "/assets/*",
                "/injected_script.js"
            ],
            "matches": [ 
                "https://rezka.ag/*",
                "https://hdrezka.cm/*",
                "https://hdrezka.me/*",
                "https://hdrezka.ag/*",
                "https://hdrezka.co/*",
                "https://rezka-ua.in/*",
                "https://rezka-ua.co/*"
            ],
            "use_dynamic_url": true
        }
    ],
    "author": "Dmytro Kazankov", 
    "homepage_url": "https://github.com/dkazankov/yard"
}